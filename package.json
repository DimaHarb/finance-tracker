{
  "name": "finance-tracker",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "turbo dev",
    "build": "turbo build",
    "lint": "turbo lint",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,json,md}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,js,jsx,json,md}\"",
    "type-check": "turbo type-check",
    "db:generate": "npm run generate --workspace=@finance-tracker/db",
    "db:migrate": "npm run migrate --workspace=@finance-tracker/db",
    "db:seed": "npm run seed --workspace=@finance-tracker/db",
    "db:studio": "npm run studio --workspace=@finance-tracker/db"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "eslint": "^9.0.0",
    "prettier": "^3.5.0",
    "prettier-plugin-tailwindcss": "^0.6.0",
    "turbo": "^2.4.0",
    "typescript": "^5.7.0",
    "typescript-eslint": "^8.57.2"
  },
  "packageManager": "npm@11.8.0",
  "engines": {
    "node": ">=20"
  }
}
